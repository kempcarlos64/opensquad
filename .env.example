# Application
APP_URL=http://127.0.0.1:3000
NODE_ENV=development

# Database and local storage (MVP)
DATABASE_URL=./data/besorah.db
STORAGE_ROOT=./data/storage

# LLM orchestration — real calls are opt-in
LLM_REAL_CALLS_ENABLED=false
OPENAI_API_KEY=
SCRIPTWRITER_MODEL=gpt-5.6-luna
JUDGE_MODEL=gpt-5.6-terra
# Configure current provider prices to persist a non-zero estimate.
SCRIPTWRITER_INPUT_PRICE_PER_MILLION=0
SCRIPTWRITER_OUTPUT_PRICE_PER_MILLION=0
JUDGE_INPUT_PRICE_PER_MILLION=0
JUDGE_OUTPUT_PRICE_PER_MILLION=0

# HeyGen v3 — server-side only; never prefix these with NEXT_PUBLIC_
HEYGEN_REAL_CALLS_ENABLED=false
HEYGEN_API_KEY=
HEYGEN_API_BASE=https://api.heygen.com
HEYGEN_WEBHOOK_SECRET=
# Temporary only: accepts the initial dashboard reachability check before the
# signing secret is available. Turn it off immediately after saving the secret.
HEYGEN_WEBHOOK_SETUP_MODE=false
HEYGEN_WEBHOOK_MAX_AGE_SECONDS=300

# Remotion worker
REMOTION_CONCURRENCY=1
REMOTION_OUTPUT_DIR=./data/renders
MOCK_VIDEO_DURATION_SECONDS=8

# Optional trend providers — only configure authorized integrations
APIFY_API_TOKEN=
YOUTUBE_API_KEY=
